const SHEET_ID = 'PASTE_YOUR_GOOGLE_SHEET_ID_HERE';
const NOTIFY_EMAIL = 'your-email@example.com';
function doPost(e){try{const d=JSON.parse(e.postData.contents||'{}');const ss=SpreadsheetApp.openById(SHEET_ID);const sh=ss.getSheetByName('orders')||ss.insertSheet('orders');if(sh.getLastRow()===0){sh.appendRow(['timestamp','order_no','name','phone','email','product','amount','payment_method','notes','status']);}const orderNo='GT-'+Utilities.formatDate(new Date(),Session.getScriptTimeZone(),'yyyyMMdd-HHmmss');sh.appendRow([new Date(),orderNo,d.name||'',d.phone||'',d.email||'',d.product||'',d.amount||'',d.payment_method||'',d.notes||'','待付款']);MailApp.sendEmail({to:NOTIFY_EMAIL,subject:'【古拉佛訂單通知】'+orderNo,htmlBody:'<h2>新訂單已建立</h2><p>訂單編號：<b>'+orderNo+'</b></p>'});return ContentService.createTextOutput(JSON.stringify({success:true,order_no:orderNo})).setMimeType(ContentService.MimeType.JSON);}catch(err){return ContentService.createTextOutput(JSON.stringify({success:false,error:String(err)})).setMimeType(ContentService.MimeType.JSON);}}